public class ConcurrentCarafe implements Carafe{
	private Carafe carafe;
	
	public ConcurrentCarafe() {
		this.carafe = new SimpleCarafe();
	}

	@Override
	public void remplir() {
		
	}

	@Override
	public void retirer(int q) {
		carafe.retirer(q);
	}

